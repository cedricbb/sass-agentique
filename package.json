{
  "name": "sass-agentique",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.1.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@saas/db": "workspace:*",
    "@saas/services": "workspace:*",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-orm": "^0.38.4",
    "prettier": "^3.5.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ],
      "allowedVersions": {
        "zod": "3 || 4"
      }
    }
  }
}
