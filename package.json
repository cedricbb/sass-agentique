{
  "name": "sass-agentique",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.1.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "prettier": "^3.5.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": ["react", "react-dom"],
      "allowedVersions": {
        "zod": "3 || 4"
      }
    }
  }
}
