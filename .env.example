# ── Database ──
DATABASE_URL="postgresql://postgres:root@localhost:5432/saas"

# ── Stripe ──
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── App ──
NODE_ENV="development"
PORT="3001"
APP_URL="http://localhost:3001"

# ── Auth ──
SESSION_SECRET="change-me-to-a-random-64-char-hex-string-for-production"

# ── Email ──

# ── Mailhog ──
SMTP_HOST="localhost"
SMTP_PORT="1025"
# SMTP_USER=   # pas nécessaire avec MailHog
# SMTP_PASS=   # pas nécessaire avec MailHog

# ── Email — Resend (production) ──
# RESEND_API_KEY="re_xxxx"
NOTIFICATIONS_ENABLED=false  # true pour activer les envois email customer (prod uniquement)

# ── TOTP ──
# TOTP_ISSUER="SaaS Agentique"

R2_ENDPOINT=

# Credentials API token créée sur dashboard R2 (scope: Object Read & Write sur le bucket cible)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket de dev (saas-reports-dev), CI (saas-reports-ci), prod (saas-reports-prod)
R2_BUCKET=
