# Database
DATABASE_URL="postgresql://postgres:root@localhost:5432/saas"

# App
NODE_ENV="development"
PORT="3001"
APP_URL="http://localhost:3001"

# Auth — Phase 1 (générer avec: openssl rand -hex 32)
SESSION_SECRET="change-me-to-a-random-64-char-hex-string-for-production"

# Email — choisir UNE option :

# Option A — MailHog (dev local, intercepte tous les emails)
SMTP_HOST="localhost"
SMTP_PORT="1025"
# SMTP_USER=   # pas nécessaire avec MailHog
# SMTP_PASS=   # pas nécessaire avec MailHog

# Option B — Resend (production)
# RESEND_API_KEY="re_xxxx"

# Option C — Autre serveur SMTP (ex: Mailtrap, Gmail...)
# SMTP_HOST="smtp.mailtrap.io"
# SMTP_PORT="587"
# SMTP_USER="mon-user"
# SMTP_PASS="mon-password"

# TOTP — Phase 4
# TOTP_ISSUER="SaaS Agentique"
